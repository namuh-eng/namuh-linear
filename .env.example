# Database -- connection string from RDS (provisioned by preflight.sh)
DATABASE_URL=postgresql://postgres:password@host:5432/namuh-linear
DB_SSL=true
DB_PASSWORD=your-db-password

# Redis -- connection string from ElastiCache (provisioned by preflight.sh)
REDIS_URL=redis://host:6379

# AWS
AWS_REGION=us-east-1

# S3 -- file attachments, avatars (provisioned by preflight.sh)
S3_BUCKET=namuh-linear-assets-us-east-1

# SES -- email sending (magic links, notifications)
SENDER_EMAIL=noreply@yourdomain.com

# Auth -- Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3015

# Auth -- Google OAuth
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3015

# Anthropic -- powers AI features (triage intelligence, auto-labeling)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Infrastructure IDs (populated by preflight.sh)
VPC_ID=
APP_SG=
DB_SG=
REDIS_SG=
ALB_SG=
PRIV_SUBNET_A=
PRIV_SUBNET_B=
PUB_SUBNET_A=
PUB_SUBNET_B=
ALB_ARN=
ALB_DNS=
TG_ARN=

# Test account — Google account for build/QA agent auth (Ever CLI uses this)
TEST_ACCOUNT_EMAIL=your-google-email@gmail.com

# Dashboard
DASHBOARD_KEY=your-dashboard-key
