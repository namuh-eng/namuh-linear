# =============================================================================
# exponential — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres)
# The app's runtime contract is a single DATABASE_URL. Store split fields in
# Secrets Manager / docker-compose and assemble the URL at the boundary.
# Default points at docker-compose.dev.yml (host port 15532).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:15532/exponential?sslmode=disable
# Fallback: if DATABASE_URL is unset, the app will build one from these.
# DB_USER=postgres
# DB_PASSWORD=password
# DB_HOST=localhost
# DB_PORT=15532
# DB_NAME=exponential
# DB_SSL=true  # Uncomment for remote/production databases

# -----------------------------------------------------------------------------
# Redis — docker-compose.dev.yml exposes Redis on host port 16379.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:16379

# -----------------------------------------------------------------------------
# Auth + public URLs (first-party Go API)
# Generate secrets with: openssl rand -hex 32
# -----------------------------------------------------------------------------
EXPONENTIAL_SESSION_SECRET=change-me-to-a-random-session-secret
EXPONENTIAL_INVITE_TOKEN_SECRET=change-me-to-a-random-invite-secret
EXPONENTIAL_APP_URL=http://localhost:7015
NEXT_PUBLIC_APP_URL=http://localhost:7015
PUBLIC_BASE_URL=http://localhost:7015
# Internal API URL used by the web process / Next.js rewrite when not set by
# Docker Compose or ECS. Host-local development usually uses localhost.
# EXPONENTIAL_API_URL=http://localhost:7016/v1

# -----------------------------------------------------------------------------
# Google OAuth (optional — required for "Continue with Google")
# Get credentials at https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# AWS — S3 (file uploads), SES (emails)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
S3_BUCKET=
SENDER_EMAIL=

# -----------------------------------------------------------------------------
# Docker Compose override ports/binds — only needed if defaults conflict.
# docker-compose.yml and docker-compose.dev.yml both default to these host ports.
# -----------------------------------------------------------------------------
# WEB_PORT=7015
# API_PORT=7016
# PG_PORT=15532
# REDIS_PORT=16379
# WEB_BIND=0.0.0.0
# API_BIND=127.0.0.1
# PG_BIND=127.0.0.1
# REDIS_BIND=127.0.0.1

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# TEST_ACCOUNT_EMAIL=test@example.com  # Used by Playwright auth setup

# -----------------------------------------------------------------------------
# AWS ECS deployment (generated by scripts/prepare-ecs-deploy-env.sh and
# scripts/preflight.sh; .env is intentionally gitignored)
# -----------------------------------------------------------------------------
# APP_NAME=exponential
# AWS_ACCOUNT_ID=
# PUBLIC_BASE_URL=https://<your-public-domain>
# PRIVATE_DNS_ZONE=exponential.internal
# PRIVATE_DNS_ZONE_ID=
# ECS_EXECUTION_ROLE_ARN=
# ECS_TASK_ROLE_ARN=
# DATABASE_URL_SECRET_ARN=
# REDIS_URL_SECRET_ARN=
# GOOGLE_CLIENT_ID_SECRET_ARN=
# GOOGLE_CLIENT_SECRET_SECRET_ARN=
# PRIV_SUBNET_A=
# PRIV_SUBNET_B=
# APP_SG=
# API_TG_ARN=
# WEB_TG_ARN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# EXPONENTIAL_TRUSTED_PROXIES=10.0.0.0/16
